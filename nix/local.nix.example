# Machine-specific configuration (work machines, extra packages, etc.)
# Copy this file to local.nix and customize. local.nix is gitignored.
#
#   cp local.nix.example local.nix
#
# Then add your hostname(s) and any customSystemSettings, customPathAdditions,
# customPackages, and customFiles per machine. Only commit the example file.

{ nixpkgs ? null }:

let
  # Load a local flake by path if it exists, returning null otherwise.
  # Useful for including locally-developed packages without hard-failing on
  # machines where the source isn't checked out.
  tryFlake = path:
    if builtins.pathExists path
    then builtins.getFlake ("path:" + path)
    else null;

in
{
  # Hostname -> { username, platform, gitUserName, gitUserEmail,
  #               customSystemSettings?, customPathAdditions?,
  #               customPackages?, customFiles? }
  systems = {
